<Window x:Class="SqueakPlayer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Squeak" Width="1280" Height="720"
        Background="Black" AllowDrop="True" Drop="Window_Drop"
        WindowStyle="None" ResizeMode="CanResize"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        KeyDown="Window_KeyDown">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0" ResizeBorderThickness="8"
                            CornerRadius="0" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid>
        <vlc:VideoView x:Name="Video">
            <!-- Everything inside VideoView renders in the airspace-fix overlay window -->
            <Grid x:Name="OverlayRoot" Background="Transparent"
                  MouseMove="Overlay_MouseMove">

                <!-- Opaque black backdrop: covers VLC's (white) video surface whenever
                     nothing is playing, so the idle screen is pure black. Collapsed
                     while a video plays so the picture shows through. -->
                <Border x:Name="Backdrop" Background="Black"/>

                <!-- Click-to-pause surface (fills area above the control bar) -->
                <Border Background="Transparent"
                        MouseLeftButtonUp="VideoSurface_Click"/>

                <!-- Center play/pause flash (fades + scales out on toggle) -->
                <Border x:Name="CenterFlash" Width="120" Height="120" CornerRadius="60"
                        Background="#66000000" IsHitTestVisible="False" Opacity="0"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        RenderTransformOrigin="0.5,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="CenterFlashScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <TextBlock x:Name="CenterFlashIcon" Text="▶" Foreground="White" FontSize="46"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <!-- OSD (volume / seek feedback, top-left) -->
                <Border x:Name="Osd" HorizontalAlignment="Left" VerticalAlignment="Top"
                        Margin="24,64,0,0" Background="#B0000000" CornerRadius="4"
                        Padding="14,7" IsHitTestVisible="False" Opacity="0">
                    <TextBlock x:Name="OsdText" Foreground="White" FontSize="16"/>
                </Border>

                <!-- Top bar: title + window buttons (slides/fades in on hover) -->
                <Border x:Name="TopBar" VerticalAlignment="Top" Height="44"
                        MouseLeftButtonDown="TopBar_MouseDown">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#CC000000" Offset="0"/>
                            <GradientStop Color="#00000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="TopSlide" Y="0"/>
                    </Border.RenderTransform>
                    <Grid>
                        <TextBlock x:Name="TitleLabel" Text="Squeak"
                                   Foreground="White" FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center" HorizontalAlignment="Left"
                                   Margin="16,0,0,0"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right" VerticalAlignment="Top"
                                    shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <Button x:Name="PinBtn" Style="{StaticResource WinButtonStyle}"
                                    Content="📌" ToolTip="Pin on top (T)"
                                    Click="Pin_Click"/>
                            <Button x:Name="MinBtn" Style="{StaticResource WinButtonStyle}" Content="—"
                                    ToolTip="Minimize" Click="Minimize_Click"/>
                            <Button x:Name="CloseBtn" Style="{StaticResource CloseButtonStyle}" Content="✕"
                                    ToolTip="Close" Click="Close_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Skip Intro -->
                <Button x:Name="SkipIntroBtn"
                        Style="{StaticResource SkipIntroStyle}"
                        Content="Skip intro  ▶❚"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="0,0,32,110"
                        Visibility="Collapsed"
                        Click="SkipIntro_Click"/>

                <!-- Bottom control bar (slides/fades in on hover) -->
                <Border x:Name="ControlBar"
                        VerticalAlignment="Bottom"
                        Padding="16,10,16,12"
                        IsHitTestVisible="True">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#00000000" Offset="0"/>
                            <GradientStop Color="#CC000000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="BarSlide" Y="0"/>
                    </Border.RenderTransform>

                    <StackPanel>
                        <Slider x:Name="SeekBar"
                                Style="{StaticResource SeekBarStyle}"
                                Minimum="0" Maximum="1000"
                                ValueChanged="SeekBar_ValueChanged"
                                MouseMove="SeekBar_MouseMove"
                                MouseLeave="SeekBar_MouseLeave"/>

                        <!-- Hover time preview above the seek bar -->
                        <Popup x:Name="SeekPreview" PlacementTarget="{Binding ElementName=SeekBar}"
                               Placement="Relative" AllowsTransparency="True"
                               IsHitTestVisible="False" Focusable="False">
                            <Border Background="#DD000000" CornerRadius="3" Padding="6,3">
                                <TextBlock x:Name="SeekPreviewText" Foreground="White" FontSize="12"/>
                            </Border>
                        </Popup>

                        <Grid Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button x:Name="PlayPauseBtn" Style="{StaticResource CtrlButtonStyle}"
                                        Width="46" Content="▶" Click="PlayPause_Click"/>
                                <Button x:Name="PrevBtn" Style="{StaticResource CtrlButtonStyle}" Width="46" Content="❚◀"
                                        ToolTip="Previous in folder" Click="Prev_Click"/>
                                <Button x:Name="NextBtn" Style="{StaticResource CtrlButtonStyle}" Width="46" Content="▶❚"
                                        ToolTip="Next in folder" Click="Next_Click"/>
                                <TextBlock x:Name="TimeLabel" Foreground="White" FontSize="13"
                                           VerticalAlignment="Center" Margin="12,0,0,0"
                                           Text="0:00 / 0:00"/>
                                <TextBlock x:Name="ChapterLabel" Foreground="#AAFFFFFF" FontSize="13"
                                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="MuteBtn" Style="{StaticResource CtrlButtonStyle}"
                                        Content="🔊" ToolTip="Wycisz (M)" Click="Mute_Click"/>
                                <Slider x:Name="VolumeSlider"
                                        Style="{StaticResource VolumeBarStyle}"
                                        Width="90" VerticalAlignment="Center"
                                        Margin="4,0,12,0"
                                        Minimum="0" Maximum="100" Value="100"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                                <Button x:Name="OpenBtn" Style="{StaticResource CtrlButtonStyle}" Content="📂"
                                        ToolTip="Open file (Ctrl+O)" Click="OpenFile_Click"/>
                                <Button x:Name="FullscreenBtn" Style="{StaticResource CtrlButtonStyle}" Content="⛶"
                                        ToolTip="Fullscreen (F)" Click="Fullscreen_Click"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Hint when nothing is loaded -->
                <TextBlock x:Name="DropHint"
                           Text="Drag a video file here, or press Ctrl+O"
                           Foreground="#88FFFFFF" FontSize="18"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>
        </vlc:VideoView>
    </Grid>
</Window>
